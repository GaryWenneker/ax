---
import '@fontsource-variable/archivo';
import '@fontsource/ibm-plex-mono/400.css';
import '../../styles/theme.css';
import LogoMark from '../../components/LogoMark.astro';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/logo.png" type="image/png" />
    <title>ax — Admin Login</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <div class="page">
      <header class="top-bar">
        <a class="wordmark" href="/">
          <LogoMark size="md" />
        </a>
        <span class="top-label">Admin</span>
      </header>

      <main class="main">
        <div class="card">
          <h1 class="card-title">Sign in</h1>
          <p class="card-sub">ax telemetry dashboard</p>

          <form id="login-form" class="form" autocomplete="off">
            <label class="field">
              <span class="field-label">Password</span>
              <input
                id="password"
                type="password"
                name="password"
                class="field-input"
                placeholder="Enter admin password"
                autocomplete="current-password"
                required
              />
            </label>
            <div id="error-msg" class="error-msg" aria-live="polite"></div>
            <button type="submit" id="submit-btn" class="btn-primary">Sign in</button>
          </form>
        </div>
      </main>
    </div>

    <script>
      const form = document.getElementById('login-form') as HTMLFormElement;
      const btn = document.getElementById('submit-btn') as HTMLButtonElement;
      const errMsg = document.getElementById('error-msg') as HTMLDivElement;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errMsg.textContent = '';
        btn.disabled = true;
        btn.textContent = 'Signing in…';

        const password = (document.getElementById('password') as HTMLInputElement).value;

        try {
          const res = await fetch('/v1/admin/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password }),
          });

          if (res.ok) {
            const { token } = await res.json() as { token: string };
            sessionStorage.setItem('ax_admin_token', token);
            window.location.href = '/admin/dashboard';
          } else {
            const data = await res.json().catch(() => ({})) as { error?: string };
            errMsg.textContent = data.error ?? 'Invalid password';
            btn.disabled = false;
            btn.textContent = 'Sign in';
          }
        } catch {
          errMsg.textContent = 'Network error. Please try again.';
          btn.disabled = false;
          btn.textContent = 'Sign in';
        }
      });
    </script>

    <style>
      :global(html) { background: var(--cg-paper); }
      :global(body) { margin: 0; font-family: var(--sl-font); color: var(--cg-ink); }

      .page {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
      }

      .top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--cg-rule);
      }
      .wordmark {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
        line-height: 0;
      }
      .top-label {
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--cg-ink-3);
      }

      .main {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
      }

      .card {
        width: 100%;
        max-width: 380px;
        border: 1px solid var(--cg-rule);
        padding: 2rem;
      }
      .card-title {
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin: 0 0 0.25rem;
      }
      .card-sub {
        font-size: 0.9rem;
        color: var(--cg-ink-2);
        margin: 0 0 1.75rem;
      }

      .form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .field {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }
      .field-label {
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--cg-ink-2);
      }
      .field-input {
        width: 100%;
        box-sizing: border-box;
        background: var(--cg-paper-2);
        border: 1px solid var(--cg-rule);
        color: var(--cg-ink);
        padding: 0.65rem 0.75rem;
        font-size: 1rem;
        font-family: var(--sl-font);
        outline: none;
        transition: border-color 0.1s;
      }
      .field-input:focus {
        border-color: var(--cg-ink);
      }

      .error-msg {
        font-size: 0.875rem;
        color: #e06c75;
        min-height: 1.25rem;
      }

      .btn-primary {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: 0.75rem;
        font-size: 1rem;
        font-weight: 600;
        font-family: var(--sl-font);
        background: var(--cg-ink);
        color: var(--cg-paper);
        border: 1px solid var(--cg-ink);
        cursor: pointer;
        transition: background 0.12s, color 0.12s;
        min-height: 44px;
      }
      .btn-primary:hover:not(:disabled) {
        background: transparent;
        color: var(--cg-ink);
      }
      .btn-primary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      @media (max-width: 480px) {
        .card {
          border: none;
          padding: 1.5rem 0;
        }
      }
    </style>
  </body>
</html>
