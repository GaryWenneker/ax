---
// Starlight header: AX dot logo + wordmark + current release tag.
import LogoMark from './LogoMark.astro';
import { AX_VERSION } from '../lib/version';

const { siteTitle } = Astro.locals.starlightRoute;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<a href={`${base}/`} class="cg-site-title" translate="no">
	<LogoMark size="sm" class="cg-site-title__logo" />
	<span class="cg-site-title__text">{siteTitle}</span>
	<span class="cg-site-title__version">{AX_VERSION}</span>
</a>

<style>
	.cg-site-title {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		font-family: var(--sl-font);
		font-weight: 800;
		font-size: 1.25rem;
		letter-spacing: -0.025em;
		line-height: 1;
		color: var(--cg-ink);
		text-decoration: none;
		white-space: nowrap;
	}
	.cg-site-title:hover {
		color: var(--cg-ink);
	}
	.cg-site-title__logo {
		opacity: 0.78;
	}
	.cg-site-title:hover .cg-site-title__logo {
		opacity: 0.92;
	}
	.cg-site-title__version {
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		color: var(--cg-ink-2);
		border: 1px solid var(--cg-rule);
		padding: 0.15rem 0.45rem;
		line-height: 1.2;
	}
</style>
