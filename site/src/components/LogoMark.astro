---
// Shared AX dot logo — partially transparent on dark backgrounds.
interface Props {
	size?: 'sm' | 'md' | 'lg' | 'hero';
	alt?: string;
	class?: string;
}

const { size = 'md', alt = 'ax', class: className = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<img
	src={`${base}/logo.jpg`}
	alt={alt}
	class:list={['ax-logo', `ax-logo--${size}`, className]}
	width="120"
	height="120"
	loading="eager"
	decoding="async"
/>

<style>
	.ax-logo {
		display: block;
		width: auto;
		height: auto;
		object-fit: contain;
		/* Partial transparency — glass logo blends into dark UI */
		opacity: 0.82;
		mix-blend-mode: screen;
		filter: drop-shadow(0 0 28px rgba(0, 220, 255, 0.12));
		transition: opacity 0.2s ease;
	}

	.ax-logo:hover {
		opacity: 0.95;
	}

	.ax-logo--sm {
		max-height: 28px;
		max-width: 72px;
	}

	.ax-logo--md {
		max-height: 36px;
		max-width: 96px;
	}

	.ax-logo--lg {
		max-height: 48px;
		max-width: 120px;
	}

	.ax-logo--hero {
		max-height: min(42vw, 280px);
		max-width: min(90vw, 420px);
		opacity: 0.72;
		mix-blend-mode: normal;
		filter: drop-shadow(0 0 48px rgba(0, 210, 255, 0.18));
	}
</style>
